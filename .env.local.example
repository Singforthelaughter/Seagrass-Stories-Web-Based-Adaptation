# Copy to .env.local and fill in. (.env.local is git-ignored.)

# Supabase (P2+). Find these in your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Replicate (P4 — AI diver texture). Already set in the repo .env for the skills/tools.
REPLICATE_API_TOKEN=
# Default image model for diver textures (you choose):
REPLICATE_MODEL=google/nano-banana-2
